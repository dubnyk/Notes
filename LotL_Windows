#check availible logs(wevtutil)
wevtutil el

#clear logs(wevtutil)
for /f %i in ('wevtutil el') do wevtutil cl %i
wevtutil cl Security
wevtutil cl Application
wevtutil cl System

#check availible logs(powershell)
Get-EventLog -List

#clear logs(powershell)
Get-EventLog -List | ForEach-Object {Clear-EventLog -LogName $_.Log}
Clear-EventLog -LogName Security

#Disable logging / restart logging
net stop eventlog
net start eventlog

#Delete Temp files
del /s /q C:\Windows\Temp\*.*
del /s /q C:\Users\<USERNAME>\AppData\Local\Temp\*.*
del /s /q C:\Users\<USERNAME>\Downloads\*.*

#Delete Browser history
rmdir "C:\Users\<USERNAME>\AppData\Local\Google\Chrome\User Data\Default\Cache" /s /q
rmdir "C:\Users\<USERNAME>\AppData\Roaming\Mozilla\Firefox\Profiles\<PROFILE_NAME>\cache2" /s /q
rmdir "C:\Users\<USERNAME>\AppData\Local\Microsoft\Edge\User Data\Default\Cache" /s /q

#Delete command history
del %userprofile%\AppData\Roaming\Microsoft\Windows\PowerShell\CommandHistory or ConsoleHost_history.txt
Remove-Item "$env:APPDATA\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt"

#Delete Prefetch
del /f /s /q %SystemRoot%\Prefetch\*.*

#Delete / modify Amcache
del /f /q "C:\Windows\AppCompat\Programs\Amcache.hve"
reg load HKLM\Amcache "C:\Windows\AppCompat\Programs\Amcache.hve"
reg query HKLM\Amcache /s
reg delete HKLM\Amcache /v <PROGRAM_GUID> /f
reg unload HKLM\Amcache

sc stop AeLookupSvc
